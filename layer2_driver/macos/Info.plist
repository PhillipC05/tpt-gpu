<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.tpt-gpu.driver</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleName</key>
    <string>TPT GPU Driver</string>
    <key>CFBundlePackageType</key>
    <string>DEXT</string>

    <!-- DriverKit entitlements -->
    <key>com.apple.developer.driverkit</key>
    <true/>
    <key>com.apple.developer.driverkit.transport.pci</key>
    <true/>
    <key>com.apple.developer.driverkit.family.gpu</key>
    <true/>

    <!-- PCI matching -->
    <key>IOKitPersonalities</key>
    <dict>
        <key>TPTDriver</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.tpt-gpu.driver</string>
            <key>IOClass</key>
            <string>IOUserService</string>
            <key>IOProviderClass</key>
            <string>IOPCIDevice</string>
            <key>IOUserClass</key>
            <string>TPTDriver</string>
            <key>IOPCIMatch</key>
            <string>0x00011A2E</string>  <!-- device:vendor little-endian -->
            <key>IOPCIPrimaryMatch</key>
            <string>0x00011A2E</string>
            <key>IOProbeScore</key>
            <integer>100000</integer>
            <key>IOUserServerName</key>
            <string>com.tpt-gpu.driver</string>
        </dict>
    </dict>
</dict>
</plist>
